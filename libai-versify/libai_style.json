  "masterpieces": [
    {
      "title": "将进酒",
      "lines": [
        "君不见黄河之水天上来，奔流到海不复回。",
        "君不见高堂明镜悲白发，朝如青丝暮成雪。",
        "人生得意须尽欢，莫使金樽空对月。",
        "天生我材必有用，千金散尽还复来。",
        "烹羊宰牛且为乐，会须一饮三百杯。"
      ],
      "tags": [
        "酒",
        "豪放",
        "人生"
      ]
    },
    {
      "title": "行路难·其一",
      "lines": [
        "金樽清酒斗十千，玉盘珍羞直万钱。",
        "停杯投箸不能食，拔剑四顾心茫然。",
        "欲渡黄河冰塞川，将登太行雪满山。",
        "闲来垂钓碧溪上，忽复乘舟梦日边。",
        "长风破浪会有时，直挂云帆济沧海。"
      ],
      "tags": [
        "剑",
        "壮志",
        "挫折"
      ]
    },
    {
      "title": "静夜思",
      "lines": [
        "床前明月光，疑是地上霜。",
        "举头望明月，低头思故乡。"
      ],
      "tags": [
        "月",
        "思乡"
      ]
    },
    {
      "title": "望庐山瀑布",
      "lines": [
        "日照香炉生紫烟，遥看瀑布挂前川。",
        "飞流直下三千尺，疑是银河落九天。"
      ],
      "tags": [
        "山水",
        "夸张",
        "想象"
      ]
    },
    {
      "title": "月下独酌",
      "lines": [
        "花间一壶酒，独酌无相亲。",
        "举杯邀明月，对影成三人。"
      ],
      "tags": [
        "月",
        "酒",
        "孤独"
      ]
    },
    {
      "title": "侠客行",
      "lines": [
        "赵客缦胡缨，吴钩霜雪明。",
        "银鞍照白马，飒沓如流星。",
        "十步杀一人，千里不留行。",
        "事了拂衣去，深藏身与名。"
      ],
      "tags": [
        "剑",
        "侠义",
        "潇洒"
      ]
    },
    {
      "title": "独坐敬亭山",
      "lines": [
        "众鸟高飞尽，孤云独去闲。",
        "相看两不厌，只有敬亭山。"
      ],
      "tags": [
        "山",
        "孤独",
        "超脱"
      ]
    },
    {
      "title": "早发白帝城",
      "lines": [
        "朝辞白帝彩云间，千里江陵一日还。",
        "两岸猿声啼不住，轻舟已过万重山。"
      ],
      "tags": [
        "水",
        "轻快",
        "自由"
      ]
    },
    {
      "title": "上李邕",
      "lines": [
        "大鹏一日同风起，扶摇直上九万里。",
        "假令风歇时下来，犹能簸却沧溟水。"
      ],
      "tags": [
        "大鹏",
        "志向",
        "自信"
      ]
    },
    {
      "title": "梦游天姥吟留别",
      "lines": [
        "海客谈瀛洲，烟涛微茫信难求。",
        "越人语天姥，云霞明灭或可睹。",
        "安能摧眉折腰事权贵，使我不得开心颜！"
      ],
      "tags": [
        "仙境",
        "不屈",
        "自由"
      ]
    },
    {
      "title": "古风·其一",
      "lines": [
        "大雅久不作，吾衰竟谁陈？",
        "王风委蔓草，战国多荆榛。"
      ],
      "tags": [
        "文学观",
        "复古"
      ]
    },
    {
      "title": "春思",
      "lines": [
        "燕草如碧丝，秦桑低绿枝。",
        "当君怀归日，是妾断肠时。"
      ],
      "tags": [
        "闺怨",
        "相思"
      ]
    }
  ],
